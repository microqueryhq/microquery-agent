# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------

# Hex private key for the wallet used to sign requests and pay for queries.
# The wallet must hold Base Sepolia ETH (for gas) and USDC (for deposits).
WALLET_PRIVATE_KEY=0x_your_private_key_here

# Address of the MicroqueryEscrow contract on Base Sepolia.
ESCROW_ADDRESS=0x_escrow_contract_address_here

# -----------------------------------------------------------------------
# Optional overrides (defaults shown)
# -----------------------------------------------------------------------

# MICROQUERY_BASE_URL=https://api.microquery.dev
# RPC_URL=https://sepolia.base.org
# USDC_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# Amount of USDC to deposit on each top-up.
# TOPUP_AMOUNT_USDC=2

# Trigger a top-up when the balance drops below this value.
# TOPUP_THRESHOLD_USDC=0.50

# -----------------------------------------------------------------------
# Optional: Claude-powered SQL generation
# -----------------------------------------------------------------------

# If set (and the anthropic package is installed), the agent will use
# Claude to generate SQL queries from each database's schema.
# ANTHROPIC_API_KEY=sk-ant-_your_key_here
